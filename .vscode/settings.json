{
  "latex-workshop.latex.autoBuild.run": "onSave",
  "latex-workshop.latex.recipe.default": "first",
  "latex-workshop.latex.outDir": "%DIR%",
  "latex-workshop.latex.cwd": "%WORKSPACE_FOLDER%",
  "latex-workshop.latex.tools": [
    {
      "name": "latexmk",
      "command": "latexmk",
      "args": [
        "-pdf",
        "-interaction=nonstopmode",
        "-synctex=1",
        "-file-line-error",
        "-output-directory=%DIR%",
        "%DOC%"
      ],
      "env": {
        "TEXINPUTS": ".:%WORKSPACE_FOLDER%//:"
      }
    },
    {
      "name": "make tidy",
      "command": "make",
      "args": ["-C", "%WORKSPACE_FOLDER%", "tidy"]
    }
  ],
  "latex-workshop.latex.recipes": [
    {
      "name": "latexmk",
      "tools": ["latexmk", "make tidy"]
    }
  ]
}
